diff --git a/src/styles/main.css b/src/styles/main.css
--- a/src/styles/main.css
+++ b/src/styles/main.css
@@
-    .mode-wrap{
-      display:flex;
-      justify-content:center;
-      margin:-6px 0 18px;
-    }
@@
-    .compact-panel-top{
-      display:flex;
-      align-items:flex-start;
-      justify-content:space-between;
-      gap:12px;
-      margin-bottom:14px;
-    }
-
-    .compact-panel-top h3{
-      margin:0 0 4px;
-      font-size:22px;
-      letter-spacing:-.03em;
-      line-height:1.1;
-    }
-
-    .compact-panel-top p{
-      margin:0;
-      color:var(--muted);
-      font-size:13px;
-      line-height:1.5;
-    }
-
-    .compact-panel-close{
-      border:none;
-      background:#f5f7fb;
-      color:#111827;
-      width:38px;
-      height:38px;
-      border-radius:12px;
-      font-size:18px;
-      font-weight:800;
-      cursor:pointer;
-      flex:0 0 auto;
-    }
-
-    .compact-panel-tabs{
-      display:flex;
-      gap:8px;
-      margin-bottom:14px;
-      flex-wrap:wrap;
-    }
-
-    .compact-panel-tab{
-      border:none;
-      border-radius:999px;
-      padding:10px 12px;
-      background:#f5f7fb;
-      color:#111827;
-      font-size:12px;
-      font-weight:800;
-      cursor:pointer;
-      transition:all .18s ease;
-    }
-
-    .compact-panel-tab.active{
-      background:linear-gradient(135deg,var(--accent),var(--accent-2));
-      color:#fff;
-    }
-
-    .compact-panel-section.hidden{
-      display:none !important;
-    }

