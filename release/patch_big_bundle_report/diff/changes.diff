+      const start = parseShiftDate(shift.start);
+      const end = parseShiftDate(shift.end);
+      if(!start || !end) return;
+
+      const ruWeek = ['Вс','Пн','Вт','Ср','Чт','Пт','Сб'];
+      const ruMonth = ['январь','февраль','март','апрель','май','июнь','июль','август','сентябрь','октябрь','ноябрь','декабрь'];
