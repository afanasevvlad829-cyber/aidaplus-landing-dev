+        : cleanId;
+      const el = document.getElementById(targetId) || document.getElementById(cleanId);
+      if(!el) return false;
+
+      el.scrollIntoView({behavior:'smooth', block:'start'});
+      return true;
+    }
+
+    function navigateToSection(id){
