# AidaCamp Telegram/Webhook integration

# Telegram Bot fallback
AIDACAMP_TELEGRAM_BOT_TOKEN=123456789:replace_with_real_bot_token
AIDACAMP_TELEGRAM_CHAT_ID=-1001234567890

# Production webhook endpoints (optional)
AIDACAMP_NOTIFY_ALL=https://hooks.example.com/aidacamp/all
AIDACAMP_NOTIFY_PROMO_FIXED=https://hooks.example.com/aidacamp/promo_fixed
AIDACAMP_NOTIFY_BOOKING_SUBMITTED=https://hooks.example.com/aidacamp/booking_submitted
AIDACAMP_NOTIFY_BOOKING_DRAFT_SAVED=https://hooks.example.com/aidacamp/booking_draft_saved
AIDACAMP_NOTIFY_PROMO_CANCELLED=https://hooks.example.com/aidacamp/promo_cancelled

# Sandbox webhook endpoint (optional)
AIDACAMP_SANDBOX_TELEGRAM_WEBHOOK=https://hooks.example.com/aidacamp/sandbox
