      "icon": "/assets/icons/lock.svg",
      "items": [
        {
          "q": "Территория закрыта?",
          "a": "Да, огорожена, КПП с охраной. Посторонние не допускаются."
        },
        {
          "q": "Сколько детей на вожатого?",
          "a": "Не более 8–10 детей, вожатые работают в парах."
        }
      ]
    },
